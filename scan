    local function flush()
        if Scan.flushing or #Scan.buffer == 0 then
            return
        end
        Scan.flushing = true
        local chunk = _table.concat(Scan.buffer, "\n") .. "\n"
        Scan.buffer = {}
        Scan.fileText = (Scan.fileText or "") .. chunk
        if #Scan.fileText > MAX_FILE_BYTES then
            Scan.fileText = stringSub(Scan.fileText, #Scan.fileText - 3200000)
            Scan.fileText = "{\"event\":\"scan_file_trimmed\",\"time\":" .. quote(now()) .. "}\n" .. Scan.fileText
        end
        writeText(filePath, Scan.fileText)
        if folderAvailable then
            writeText(folder .. "/latest.log", Scan.fileText)
        end
        Scan.flushing = false
    end

    local function logRecord(record)
        if not Scan.active then
            return
        end
        record.time = now()
        local ok, encoded = safeCall(function()
            return encode(record)
        end)
        if not ok then
            encoded = encode({ event = "encode_error", message = shortString(encoded, 500), time = now() })
        end
        Scan.buffer[#Scan.buffer + 1] = encoded
        inc(record.event or "unknown")
        if #Scan.buffer >= FLUSH_EVERY then
            flush()
        end
    end

    function Scan:Connect(signal, callback)
        if not self.active or not signal or not callable(callback) then
            return nil
        end
        local ok, conn = safeCall(function()
            if signal.Connect then
                return signal:Connect(callback)
            end
            return nil
        end)
        if ok and conn then
            self.conns[#self.conns + 1] = conn
            return conn
        end
        return nil
    end

    function Scan:Stop(reason)
        if not self.active then
            return
        end
        logRecord({ event = "scan_stop", reason = safeToString(reason or "manual") })
        self.active = false
        for _, conn in _ipairs(self.conns) do
            safeCall(function()
                if conn and conn.Disconnect then
                    conn:Disconnect()
                end
            end)
        end
        flush()
    end

