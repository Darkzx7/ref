    local function ancestorNamed(instance, wantedName)
        local wanted = stringLower(wantedName or "")
        local current = instance
        local limit = 0
        while current and limit < 40 do
            local currentName = stringLower(prop(current, "Name") or "")
            if currentName == wanted then
                return current
            end
            if current == Workspace then
                return nil
            end
            current = parentOf(current)
            limit = limit + 1
        end
        return nil
    end

    local function directChildInfos(root, limit)
        local children = {}
        limit = limit or 12
        safeCall(function()
            children = root:GetChildren()
        end)
        local result = {}
        for _, child in _ipairs(children) do
            if #result >= limit then
                break
            end
            result[#result + 1] = {
                class = safeToString(prop(child, "ClassName") or "Unknown"),
                name = safeToString(prop(child, "Name") or "Unknown"),
            }
        end
        return result
    end

    local function objectPosition(instance)
        local pos = nil
        if isA(instance, "BasePart") then
            safeCall(function()
                pos = instance.Position
            end)
        elseif isA(instance, "Model") then
            safeCall(function()
                pos = instance:GetPivot().Position
            end)
        elseif isA(instance, "Tool") then
            local handle = nil
            safeCall(function()
                handle = instance:FindFirstChild("Handle")
            end)
            if handle then
                safeCall(function()
                    pos = handle.Position
                end)
            end
        end
        if pos then
            return serialize(pos)
        end
        return nil
    end

    local function objectSignature(instance, position)
        local path = pathText(instance)
        if position and position.x and position.y and position.z then
            return path .. "@" .. safeToString(position.x) .. "," .. safeToString(position.y) .. "," .. safeToString(position.z)
        end
        return path
    end

    local function attributesInfo(instance)
        local attrs = nil
        safeCall(function()
            if instance.GetAttributes then
                attrs = instance:GetAttributes()
            end
        end)
        if _type(attrs) == "table" and tableCount(attrs) > 0 then
            return serialize(attrs)
        end
        return nil
    end

    local function tagsForPath(path)
        local tags = {}
        if containsAny(path, coinTerms) then tags[#tags + 1] = "coin" end
        if containsAny(path, gunDropTerms) then tags[#tags + 1] = "gun_drop" end
        if containsAny(path, roundStartTerms) or containsAny(path, roundEndTerms) then tags[#tags + 1] = "round" end
        if containsAny(path, roleTerms) then tags[#tags + 1] = "role" end
        if containsAny(path, { "remote", "gameplay", "clientservice", "weaponservice" }) then tags[#tags + 1] = "event" end
        if #tags == 0 and containsAny(path, interestingTerms) then tags[#tags + 1] = "interesting" end
        return tags
    end

    local function isRemote(instance)
        return isA(instance, "RemoteEvent") or isA(instance, "RemoteFunction")
    end

    local function setPhase(phase, source, reason, packedArgs)
        if not phase or phase == "" then
            return
        end
        if Scan.summary.currentPhase ~= phase then
            Scan.summary.currentPhase = phase
            logRecord({
                event = "phase_signal",
                phase = phase,
                source = source,
                reason = reason,
                args = packedArgs,
            })
        else
            Scan.summary.currentPhase = phase
        end
    end

    local function inferRoundFromRemote(remote, packedArgs)
        local path = pathText(remote)
        if containsAny(path, roundStartTerms) then
            Scan.summary.lastRoundState = "started_or_role_assignment"
            logRecord({ event = "round_state_signal", state = Scan.summary.lastRoundState, source = instanceInfo(remote), args = packedArgs })
            if stringFind(path, "RoleSelect") then
                setPhase("role_select", instanceInfo(remote), "role_select_signal", packedArgs)
            elseif stringFind(path, "RoundStart") or stringFind(path, "GiveWeapon") then
                setPhase("in_round", instanceInfo(remote), "round_start_signal", packedArgs)
            end
        elseif containsAny(path, roundEndTerms) then
            Scan.summary.lastRoundState = "ended_or_transition"
            logRecord({ event = "round_state_signal", state = Scan.summary.lastRoundState, source = instanceInfo(remote), args = packedArgs })
            if containsAny(path, lobbyEndTerms) then
                Scan.summary.lastLobbySignal = path
                setPhase("lobby", instanceInfo(remote), "round_end_lobby_signal", packedArgs)
            elseif stringFind(path, "Clear1v1") or stringFind(path, "Cancelled1v1") then
                Scan.summary.lastLobbySignal = path
                setPhase("lobby_transition", instanceInfo(remote), "round_transition_signal", packedArgs)
            end
        end
        if containsAny(path, roleTerms) then
            Scan.summary.lastRoleSignal = path
            logRecord({ event = "role_state_signal", source = instanceInfo(remote), args = packedArgs })
        end
    end

    local function rawArg(rawArgs, index)
        if _type(rawArgs) ~= "table" then
            return nil
        end
        return rawArgs[index]
    end

    local function summaryFieldValue(entry, fieldName)
        if _type(entry) ~= "table" or _type(entry.data) ~= "table" or _type(entry.data.fields) ~= "table" then
            return nil
        end
        local field = entry.data.fields[fieldName]
        if _type(field) == "table" then
            return field.value
        end
        return nil
    end

    local function logSpecialInbound(remote, packedArgs, rawArgs)
        local path = pathText(remote)

        if stringFind(path, "PlayerDataChanged") then
            local playerSummary = summarizePlayerData(rawArg(rawArgs, 1))
            Scan.summary.lastRoleSignal = path
            if (playerSummary.playerCount or 0) > 0 then
                Scan.summary.lastRoles = {
                    murderer = playerSummary.murderer,
                    sheriff = playerSummary.sheriff,
                    hero = playerSummary.hero,
                    localPlayer = playerSummary.localPlayer,
                }
                if playerSummary.localPlayer then
                    local localRole = playerSummary.localPlayer.role
                    if localRole and localRole ~= "unknown" then
                        Scan.summary.lastLocalRole = localRole
                    end
                    Scan.summary.lastLocalGun = summaryFieldValue(playerSummary.localPlayer, "Gun") or Scan.summary.lastLocalGun
                    Scan.summary.lastLocalKnife = summaryFieldValue(playerSummary.localPlayer, "Knife") or Scan.summary.lastLocalKnife
                end
            end
            logRecord({
                event = "player_data_summary",
                source = instanceInfo(remote),
                summary = playerSummary,
                retainedAsLastRoles = (playerSummary.playerCount or 0) > 0,
            })
            return
        end

        if stringFind(path, "GiveWeapon") then
            local weapon = rawArg(rawArgs, 1)
            local weaponText = safeToString(weapon or "")
            local role = weaponRole(weaponText)
            Scan.summary.lastLocalWeapon = weaponText
            if role then
                Scan.summary.lastLocalRole = role
            end
            Scan.summary.lastRoundState = "started_or_role_assignment"
            logRecord({
                event = "give_weapon_signal",
                source = instanceInfo(remote),
                weapon = primitiveSummary(weapon),
                inferredLocalRole = role or "unknown",
                args = packedArgs,
            })
            return
        end

        if stringFind(path, "CoinCollected") then
            local coinType = rawArg(rawArgs, 1)
            local currentCount = rawArg(rawArgs, 2)
            local coinLimit = rawArg(rawArgs, 3)
            Scan.summary.lastCoinCount = currentCount or "unknown"
            Scan.summary.lastCoinLimit = coinLimit or "unknown"
            logRecord({
                event = "coin_collected_signal",
                source = instanceInfo(remote),
                coinType = primitiveSummary(coinType),
                currentCount = primitiveSummary(currentCount),
                coinLimit = primitiveSummary(coinLimit),
                metadata = serialize(rawArg(rawArgs, 4)),
            })
            return
        end

        if containsAny(path, { "victoryscreen", "defeatscreen", "losescreen" }) then
            Scan.summary.lastRoundState = "ended_or_transition"
            Scan.summary.lastLobbySignal = path
            Scan.summary.lastRoundEndReason = safeToString(rawArg(rawArgs, 3) or "unknown")
            setPhase("lobby", instanceInfo(remote), "end_screen", packedArgs)
            logRecord({
                event = "round_end_summary",
                source = instanceInfo(remote),
                phase = Scan.summary.currentPhase,
                lobbyOnly = true,
                didLocalWin = primitiveSummary(rawArg(rawArgs, 1)),
                winningRole = primitiveSummary(rawArg(rawArgs, 2)),
                reason = primitiveSummary(rawArg(rawArgs, 3)),
                creditedPlayer = primitiveSummary(rawArg(rawArgs, 4)),
                roundNumber = primitiveSummary(rawArg(rawArgs, 5)),
                args = packedArgs,
            })
            return
        end

        if stringFind(path, "RoundEndFade") or stringFind(path, "Clear1v1") or stringFind(path, "Cancelled1v1") then
            Scan.summary.lastRoundState = "ended_or_transition"
            Scan.summary.lastLobbySignal = path
            logRecord({
                event = "round_transition_signal",
                state = Scan.summary.lastRoundState,
                phase = Scan.summary.currentPhase,
                source = instanceInfo(remote),
                args = packedArgs,
            })
            return
        end
    end

    local function attachInbound(remote)
        if Scan.inboundRemotes[remote] or not isA(remote, "RemoteEvent") then
            return
        end
        Scan.inboundRemotes[remote] = true
        local signal = prop(remote, "OnClientEvent")
        Scan:Connect(signal, function(...)
            protected("remote_inbound", function(...)
                local rawArgs = { ... }
                rawArgs.n = _select("#", ...)
                local packed = packArgs(...)
                logRecord({ event = "remote_inbound", method = "OnClientEvent", remote = instanceInfo(remote), tags = tagsForPath(pathText(remote)), args = packed })
                inferRoundFromRemote(remote, packed)
                logSpecialInbound(remote, packed, rawArgs)
            end, ...)
        end)
    end

    local function rememberRemote(remote)
        if not isRemote(remote) or Scan.discoveredRemotes[remote] then
            return
        end
        Scan.discoveredRemotes[remote] = true
        local path = pathText(remote)
        logRecord({ event = "remote_discovered", remote = instanceInfo(remote), tags = tagsForPath(path), attributes = attributesInfo(remote) })
        attachInbound(remote)
    end

    local function readValue(instance)
        local ok, value = safeCall(function()
            return instance.Value
        end)
        if ok then
            return serialize(value)
        end
        return { type = "read_error", value = shortString(value, 200) }
    end

    local function watchValue(instance, reason)
        if Scan.watchedValues[instance] or not isA(instance, "ValueBase") then
            return
        end
        local path = pathText(instance)
        if not containsAny(path, interestingTerms) then
            return
        end
        Scan.watchedValues[instance] = true
        Scan.summary.valueStatesSeen = Scan.summary.valueStatesSeen + 1
        logRecord({ event = "state_value_discovered", reason = reason, valueObject = instanceInfo(instance), value = readValue(instance), tags = tagsForPath(path), attributes = attributesInfo(instance) })
        Scan:Connect(prop(instance, "Changed"), function()
            protected("state_value_changed", function()
                local value = readValue(instance)
                local tags = tagsForPath(pathText(instance))
                if containsAny(pathText(instance), roundStartTerms) then
                    Scan.summary.lastRoundState = "value_started_or_active"
                elseif containsAny(pathText(instance), roundEndTerms) then
                    Scan.summary.lastRoundState = "value_ended_or_transition"
                end
                logRecord({ event = "state_value_changed", valueObject = instanceInfo(instance), value = value, tags = tags })
            end)
        end)
    end

    local function watchAttributes(instance, reason)
        if Scan.watchedAttributes[instance] then
            return
        end
        local path = pathText(instance)
        if not containsAny(path, interestingTerms) then
            return
        end
        local attrs = attributesInfo(instance)
        if not attrs then
            return
        end
        Scan.watchedAttributes[instance] = true
        logRecord({ event = "attributes_discovered", reason = reason, instance = instanceInfo(instance), tags = tagsForPath(path), attributes = attrs })

        local rawAttrs = nil
        safeCall(function()
            rawAttrs = instance:GetAttributes()
        end)
        if _type(rawAttrs) == "table" then
            for attrName in _pairs(rawAttrs) do
                safeCall(function()
                    local signal = instance:GetAttributeChangedSignal(attrName)
                    Scan:Connect(signal, function()
                        protected("attribute_changed", function()
                            local value = nil
                            safeCall(function()
                                value = instance:GetAttribute(attrName)
                            end)
                            logRecord({
                                event = "attribute_changed",
                                instance = instanceInfo(instance),
                                attribute = safeToString(attrName),
                                value = serialize(value),
                                tags = tagsForPath(pathText(instance)),
                            })
                        end)
                    end)
                end)
            end
        end
    end

    local function positionFromDescendant(root, childName)
        local child = findChild(root, childName, true)
        if child then
            return objectPosition(child)
        end
        return nil
    end

    local function hasDescendantNamed(root, childName)
        return findChild(root, childName, true) ~= nil
    end

    local function mapNameFor(instance)
        local current = instance
        local previous = nil
        local limit = 0
        while current and current ~= Workspace and limit < 40 do
            previous = current
            current = parentOf(current)
            limit = limit + 1
        end
        if previous and previous ~= instance then
            return safeToString(prop(previous, "Name") or "")
        end
        local parent = parentOf(instance)
        return parent and safeToString(prop(parent, "Name") or "") or "unknown"
    end

    local function canonicalCoinRoot(instance)
        if not inWorkspace(instance) then
            return nil, nil
        end

        local root = ancestorNamed(instance, "Coin_Server")
        if root then
            return root, "coin_server_ancestor"
        end
        return nil, nil
    end

    local function canonicalGunDropRoot(instance)
        if not inWorkspace(instance) then
            return nil, nil
        end
        local root = ancestorNamed(instance, "GunDrop")
        if root then
            return root, "gundrop_ancestor"
        end
        return nil, nil
    end

    local function classifyWorldObject(instance)
        if not inWorkspace(instance) then
            return
        end

        local coinRoot, coinReason = canonicalCoinRoot(instance)
        local coinPosition = coinRoot and (positionFromDescendant(coinRoot, "MainCoin") or objectPosition(coinRoot)) or nil
        local coinKey = coinRoot and objectSignature(coinRoot, coinPosition) or nil
        if coinRoot and coinKey and not Scan.coinObjectKeys[coinKey] then
            Scan.coinObjects[coinRoot] = true
            Scan.coinObjectKeys[coinKey] = true
            Scan.coinRemovedObjects[coinRoot] = nil
            Scan.coinRemovedKeys[coinKey] = nil
            Scan.summary.coinsSeen = Scan.summary.coinsSeen + 1
            logRecord({
                event = "coin_object_discovered",
                object = instanceInfo(coinRoot),
                map = mapNameFor(coinRoot),
                position = coinPosition,
                signature = coinKey,
                hasTouchInterest = hasDescendantNamed(coinRoot, "TouchInterest"),
                attributes = attributesInfo(coinRoot),
                reason = coinReason,
            })
        end

        local gunDropRoot, gunDropReason = canonicalGunDropRoot(instance)
        local gunDropPosition = gunDropRoot and objectPosition(gunDropRoot) or nil
        local gunDropKey = gunDropRoot and objectSignature(gunDropRoot, gunDropPosition) or nil
        if gunDropRoot and gunDropKey and not Scan.gunDropObjectKeys[gunDropKey] then
            Scan.gunDropObjects[gunDropRoot] = true
            Scan.gunDropObjectKeys[gunDropKey] = true
            Scan.gunDropRemovedObjects[gunDropRoot] = nil
            Scan.gunDropRemovedKeys[gunDropKey] = nil
            Scan.summary.gunDropsSeen = Scan.summary.gunDropsSeen + 1
            logRecord({
                event = "gun_drop_object_discovered",
                object = instanceInfo(gunDropRoot),
                map = mapNameFor(gunDropRoot),
                position = gunDropPosition,
                signature = gunDropKey,
                hasTouchInterest = hasDescendantNamed(gunDropRoot, "TouchInterest"),
                children = directChildInfos(gunDropRoot, 12),
                attributes = attributesInfo(gunDropRoot),
                reason = gunDropReason,
            })
        end
    end

    local function inspectInstance(instance, reason)
        if not instance or not Scan.active then
            return
        end
        rememberRemote(instance)
        watchValue(instance, reason)
        watchAttributes(instance, reason)
        classifyWorldObject(instance)
    end

    local function safeWait(seconds)
        if _type(task) == "table" and callable(task.wait) then
            local ok = safeCall(task.wait, seconds)
            if ok then
                return
            end
        end
        if callable(wait) then
            safeCall(wait, seconds)
            return
        end
        if RunService then
            local heartbeat = prop(RunService, "Heartbeat")
            if heartbeat and heartbeat.Wait then
                safeCall(function()
                    heartbeat:Wait()
                end)
            end
        end
    end

    local function scanRoot(root, reason)
        if not root or not Scan.active then
            return
        end
        local firstRootScan = Scan.scannedRoots[root] ~= true
        Scan.scannedRoots[root] = true

        inspectInstance(root, reason)
        local ok, descendants = safeCall(function()
            return root:GetDescendants()
        end)
        if ok and _type(descendants) == "table" then
            for index, instance in _ipairs(descendants) do
                inspectInstance(instance, reason)
                if index % 300 == 0 then
                    safeWait()
                end
            end
        end

        if not firstRootScan then
            return
        end

        local addedSignal = prop(root, "DescendantAdded")
        Scan:Connect(addedSignal, function(instance)
            if _type(task) == "table" and callable(task.defer) then
                local okDefer = safeCall(task.defer, function()
                    protected("descendant_added", function()
                        inspectInstance(instance, "descendant_added")
                    end)
                end)
                if okDefer then
                    return
                end
            end
            protected("descendant_added_direct", function()
                inspectInstance(instance, "descendant_added")
            end)
        end)

        local removingSignal = prop(root, "DescendantRemoving")
        Scan:Connect(removingSignal, function(instance)
            protected("descendant_removing", function()
                local coinRoot = canonicalCoinRoot(instance)
                local coinPosition = coinRoot and (positionFromDescendant(coinRoot, "MainCoin") or objectPosition(coinRoot)) or nil
                local coinKey = coinRoot and objectSignature(coinRoot, coinPosition) or nil
                if coinRoot and coinKey and Scan.coinObjectKeys[coinKey] and not Scan.coinRemovedKeys[coinKey] then
                    Scan.coinRemovedObjects[coinRoot] = true
                    Scan.coinRemovedKeys[coinKey] = true
                    logRecord({ event = "coin_object_removed", object = instanceInfo(coinRoot), map = mapNameFor(coinRoot), position = coinPosition, signature = coinKey })
                end
                local gunDropRoot = canonicalGunDropRoot(instance)
                local gunDropPosition = gunDropRoot and objectPosition(gunDropRoot) or nil
                local gunDropKey = gunDropRoot and objectSignature(gunDropRoot, gunDropPosition) or nil
                if gunDropRoot and gunDropKey and Scan.gunDropObjectKeys[gunDropKey] and not Scan.gunDropRemovedKeys[gunDropKey] then
                    Scan.gunDropRemovedObjects[gunDropRoot] = true
                    Scan.gunDropRemovedKeys[gunDropKey] = true
                    logRecord({ event = "gun_drop_object_removed", object = instanceInfo(gunDropRoot), map = mapNameFor(gunDropRoot), position = gunDropPosition, signature = gunDropKey })
                end
            end)
        end)
    end

    local function roots()
        local list = {}
        local names = { "ReplicatedStorage", "ReplicatedFirst", "Workspace", "Lighting", "StarterGui", "StarterPack", "StarterPlayer" }
        for _, name in _ipairs(names) do
            local service = getService(name)
            if service then
                list[#list + 1] = service
            end
        end
        if LocalPlayer then
            list[#list + 1] = LocalPlayer
            local playerGui = prop(LocalPlayer, "PlayerGui")
            local backpack = prop(LocalPlayer, "Backpack")
            local character = prop(LocalPlayer, "Character")
            if playerGui then list[#list + 1] = playerGui end
            if backpack then list[#list + 1] = backpack end
            if character then list[#list + 1] = character end
        end
        return list
    end

    local function updateStatus()
        local text = "running: " .. VERSION
            .. "\nmode: passive state scan/no outbound hook/no remote firing"
            .. "\nfile: " .. filePath
            .. "\ncoinsSeen: " .. safeToString(Scan.summary.coinsSeen)
            .. "\ngunDropsSeen: " .. safeToString(Scan.summary.gunDropsSeen)
            .. "\nvalueStatesSeen: " .. safeToString(Scan.summary.valueStatesSeen)
            .. "\ncurrentPhase: " .. safeToString(Scan.summary.currentPhase)
            .. "\nlastRoundState: " .. safeToString(Scan.summary.lastRoundState)
            .. "\nlastLobbySignal: " .. safeToString(Scan.summary.lastLobbySignal)
            .. "\nlastRoundEndReason: " .. safeToString(Scan.summary.lastRoundEndReason)
            .. "\nlastRoleSignal: " .. safeToString(Scan.summary.lastRoleSignal)
            .. "\nlastLocalRole: " .. safeToString(Scan.summary.lastLocalRole)
            .. "\nlastLocalWeapon: " .. safeToString(Scan.summary.lastLocalWeapon)
            .. "\nlastLocalGun: " .. safeToString(Scan.summary.lastLocalGun)
            .. "\nlastLocalKnife: " .. safeToString(Scan.summary.lastLocalKnife)
            .. "\nlastCoinCount: " .. safeToString(Scan.summary.lastCoinCount) .. "/" .. safeToString(Scan.summary.lastCoinLimit)
            .. "\n"
        writeText(statusPath, text)
        if folderAvailable then
            writeText(folder .. "/status.txt", text)
        end
    end

    local function spawnTask(name, callback)
        local runner = function()
            protected(name, callback)
        end
        if _type(task) == "table" and callable(task.spawn) then
            local ok = safeCall(task.spawn, runner)
            if ok then
                return
            end
        end
        if callable(spawn) then
            local ok = safeCall(spawn, runner)
            if ok then
                return
            end
        end
        if _type(_coroutine) == "table" and callable(_coroutine.wrap) then
            local ok, wrapped = safeCall(_coroutine.wrap, runner)
            if ok and callable(wrapped) then
                safeCall(wrapped)
                return
            end
        end
        runner()
    end

    writeText(filePath, "")

    logRecord({
        event = "scan_start",
        version = VERSION,
        file = filePath,
        placeId = prop(_game, "PlaceId"),
        jobId = safeToString(prop(_game, "JobId") or ""),
        localPlayer = LocalPlayer and { name = safeToString(prop(LocalPlayer, "Name") or ""), userId = prop(LocalPlayer, "UserId") } or nil,
        capabilities = {
            writefile = callable(writefileFn),
            outboundHook = false,
            remoteFiring = false,
        },
        focus = {
            "coin_server_only_deduped",
            "gundrop_deduped",
            "round_state",
            "phase_lobby_detection",
            "player_data_role_summary",
            "give_weapon_local_role",
            "remote_names",
            "inbound_events",
        },
    })

    spawnTask("initial_scan", function()
        for _, root in _ipairs(roots()) do
            if Scan.active then
                scanRoot(root, "initial_scan")
            end
        end
        if LocalPlayer then
            Scan:Connect(prop(LocalPlayer, "CharacterAdded"), function(character)
                protected("character_added", function()
                    scanRoot(character, "character_added")
                end)
            end)
        end
        logRecord({ event = "initial_scan_complete", summary = Scan.summary })
        flush()
        updateStatus()
    end)

    spawnTask("periodic_rescan", function()
        while Scan.active do
            safeWait(12)
            if Workspace then
                scanRoot(Workspace, "periodic_workspace_rescan")
            end
            if ReplicatedStorage then
                scanRoot(ReplicatedStorage, "periodic_replicated_rescan")
            end
            logRecord({ event = "scan_heartbeat", counts = Scan.counts, bufferSize = #Scan.buffer, summary = Scan.summary })
            flush()
            updateStatus()
        end
    end)

    spawnTask("flush_loop", function()
        while Scan.active do
            safeWait(2)
            flush()
            updateStatus()
        end
    end)

    flush()
    updateStatus()
end

local ok = protected("main", main)
if not ok then
    writeText(statusPath, "main failed; check " .. crashPath .. "\n")
end
