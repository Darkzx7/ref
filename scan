        value = stringGsub(value, "\r", "\\r")
        value = stringGsub(value, "\t", "\\t")
        value = stringGsub(value, "[%z\1-\31]", function(char)
            return stringFormat("\\u%04x", stringByte(char))
        end)
        return "\"" .. value .. "\""
    end

    local function isArray(tbl)
        if _type(tbl) ~= "table" then
