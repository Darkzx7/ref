    local function tableKeys(tbl, limit)
        local keys = {}
        limit = limit or 40
        if _type(tbl) ~= "table" then
            return keys
        end
        for key in _pairs(tbl) do
            if #keys >= limit then
                break
            end
            keys[#keys + 1] = shortString(key, 80)
        end
        if _type(_table) == "table" and callable(_table.sort) then
            safeCall(_table.sort, keys)
        end
        return keys
    end

    local function compactImportantFields(tbl, depth)
        depth = depth or 0
        if _type(tbl) ~= "table" then
            return primitiveSummary(tbl) or { type = kind(tbl), value = shortString(tbl, 120) }
        end
        if depth > 2 then
            return { type = "table", count = tableCount(tbl), truncated = "summary-depth" }
        end

        local fields = {}
        local added = 0
        for key, item in _pairs(tbl) do
            local keyText = safeToString(key)
            local scalar = primitiveSummary(item)
            local roleMatch = scalar and scalar.value and roleFromText(scalar.value)
            if importantKey(keyText) or roleMatch then
                if scalar then
                    fields[keyText] = scalar
                else
                    fields[keyText] = compactImportantFields(item, depth + 1)
                end
                added = added + 1
                if added >= 30 then
                    break
                end
            elseif _type(item) == "table" and depth < 1 then
                local nested = compactImportantFields(item, depth + 1)
                if nested and nested.fields and tableCount(nested.fields) > 0 then
                    fields[keyText] = nested
                    added = added + 1
                end
            end
        end

        return { type = "table", count = tableCount(tbl), keys = tableKeys(tbl, 35), fields = fields }
    end

    local function findRoleInTable(tbl, depth)
        depth = depth or 0
        if _type(tbl) ~= "table" or depth > 3 then
            return nil
        end
        for key, item in _pairs(tbl) do
            local keyText = safeToString(key)
            if _type(item) == "string" then
                local role = roleFromText(item)
                if role and (importantKey(keyText) or roleFromText(keyText) or keyText == "Role") then
                    return role
                end
            elseif _type(item) == "table" then
                local role = findRoleInTable(item, depth + 1)
                if role then
                    return role
                end
            end
        end
        return nil
    end

    local function summarizePlayerData(data)
        local summary = {
            playerCount = tableCount(data),
            players = {},
            murderer = nil,
            sheriff = nil,
            hero = nil,
            localPlayer = nil,
        }
        if _type(data) ~= "table" then
            summary.raw = primitiveSummary(data) or serialize(data)
            return summary
        end

        local localName = LocalPlayer and safeToString(prop(LocalPlayer, "Name") or "") or ""
        for playerName, playerData in _pairs(data) do
            local nameText = safeToString(playerName)
            local role = findRoleInTable(playerData)
            local entry = {
                name = nameText,
                role = role or "unknown",
                data = compactImportantFields(playerData),
            }
            if #summary.players < 30 then
                summary.players[#summary.players + 1] = entry
            end
            if role == "Murderer" then
                summary.murderer = nameText
            elseif role == "Sheriff" then
                summary.sheriff = nameText
            elseif role == "Hero" then
                summary.hero = nameText
            end
            if localName ~= "" and nameText == localName then
                summary.localPlayer = entry
            end
        end
        return summary
    end

    local function inc(eventName)
