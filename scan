    local function stringLower(text)
        text = safeToString(text or "")
        if _type(_string) == "table" and callable(_string.lower) then
            local ok, result = safeCall(_string.lower, text)
            if ok then
                return result
            end
        end
        return text
    end

    local function stringFind(text, pattern)
        if _type(_string) == "table" and callable(_string.find) then
            local ok, result = safeCall(_string.find, text, pattern, 1, true)
            return ok and result ~= nil
        end
        return false
    end

    local function containsAny(text, terms)
        local lower = stringLower(text)
        for _, term in _ipairs(terms) do
            if stringFind(lower, stringLower(term)) then
                return true
            end
        end
        return false
    end

    local function stringGsub(text, pattern, repl)
        if _type(_string) == "table" and callable(_string.gsub) then
            local ok, result = safeCall(_string.gsub, text, pattern, repl)
            if ok then
                return result
            end
        end
        return text
    end

    local function stringByte(char)
        if _type(_string) == "table" and callable(_string.byte) then
            local ok, result = safeCall(_string.byte, char)
            if ok and result then
                return result
            end
        end
        return 0
    end

    local function stringFormat(fmt, ...)
        if _type(_string) == "table" and callable(_string.format) then
            local ok, result = safeCall(_string.format, fmt, ...)
            if ok and result then
                return result
            end
        end
        return ""
    end

    local function stringSub(text, a, b)
        if _type(_string) == "table" and callable(_string.sub) then
            local ok, result = safeCall(_string.sub, text, a, b)
            if ok then
                return result
            end
        end
        return text
    end

    local function quote(value)
        value = safeToString(value or "")
        value = stringGsub(value, "\\", "\\\\")
        value = stringGsub(value, "\"", "\\\"")
        value = stringGsub(value, "\b", "\\b")
        value = stringGsub(value, "\f", "\\f")
        value = stringGsub(value, "\n", "\\n")
        value = stringGsub(value, "\r", "\\r")
        value = stringGsub(value, "\t", "\\t")
        value = stringGsub(value, "[%z\1-\31]", function(char)
            return stringFormat("\\u%04x", stringByte(char))
        end)
        return "\"" .. value .. "\""
    end

    local function isArray(tbl)
        if _type(tbl) ~= "table" then
            return false
        end
        local count = 0
        local maxIndex = 0
        for key in _pairs(tbl) do
            if _type(key) ~= "number" or key < 1 or key % 1 ~= 0 then
                return false
            end
            count = count + 1
            if key > maxIndex then
                maxIndex = key
            end
        end
        return count == maxIndex
    end

    local function encode(value, depth)
        depth = depth or 0
        local valueType = _type(value)
        if value == nil then
            return "null"
        end
        if valueType == "boolean" or valueType == "number" then
            return safeToString(value)
        end
        if valueType == "string" then
            return quote(value)
        end
        if valueType ~= "table" then
            return quote(safeToString(value))
        end
        if depth > 6 then
            return quote("[max-depth]")
        end

        local parts = {}
        if isArray(value) then
            for index = 1, #value do
                parts[#parts + 1] = encode(value[index], depth + 1)
            end
            return "[" .. _table.concat(parts, ",") .. "]"
        end

        for key, item in _pairs(value) do
            parts[#parts + 1] = quote(safeToString(key)) .. ":" .. encode(item, depth + 1)
        end
        if _type(_table) == "table" and callable(_table.sort) then
            safeCall(_table.sort, parts)
        end
        return "{" .. _table.concat(parts, ",") .. "}"
    end

    local function shortString(value, maxLength)
        value = safeToString(value)
        maxLength = maxLength or 300
        if #value > maxLength then
            return stringSub(value, 1, maxLength) .. "...[truncated]"
        end
        return value
    end

    local function numberValue(value)
        if _type(value) ~= "number" then
            return safeToString(value)
        end
        if _type(_math) == "table" and callable(_math.floor) then
            local ok, rounded = safeCall(function()
                return _math.floor(value * 10000 + 0.5) / 10000
            end)
            if ok then
                return rounded
            end
        end
        return value
    end

    local function tableCount(tbl)
        local count = 0
        if _type(tbl) == "table" then
            for _ in _pairs(tbl) do
                count = count + 1
            end
        end
        return count
    end

    local serialize
    serialize = function(value, depth, seen)
        depth = depth or 0
        seen = seen or {}
        local valueType = kind(value)
        if value == nil then
            return { type = "nil" }
        end
        if valueType == "boolean" or valueType == "number" then
            return { type = valueType, value = value }
        end
        if valueType == "string" then
            return { type = "string", value = shortString(value, 800), length = #value }
        end
        if valueType == "Instance" then
            return {
                type = "Instance",
                class = safeToString(prop(value, "ClassName") or "Unknown"),
                name = safeToString(prop(value, "Name") or "Unknown"),
                path = fullName(value),
            }
        end
        if valueType == "Vector2" then
            return { type = "Vector2", x = numberValue(value.X), y = numberValue(value.Y) }
        end
        if valueType == "Vector3" then
            return { type = "Vector3", x = numberValue(value.X), y = numberValue(value.Y), z = numberValue(value.Z) }
        end
        if valueType == "CFrame" then
            local ok, components = safeCall(function()
                return { value:GetComponents() }
            end)
            return { type = "CFrame", components = ok and components or safeToString(value) }
        end
        if valueType == "Color3" then
            return { type = "Color3", r = numberValue(value.R), g = numberValue(value.G), b = numberValue(value.B) }
        end
        if valueType == "EnumItem" then
            return { type = "EnumItem", value = safeToString(value) }
        end
        if valueType == "table" then
            if seen[value] then
                return { type = "table", circular = true }
            end
            if depth >= 3 then
                return { type = "table", count = tableCount(value), truncated = "max-depth" }
            end
            seen[value] = true
            local entries = {}
            local total = 0
            for key, item in _pairs(value) do
                total = total + 1
                if #entries < 35 then
                    entries[#entries + 1] = {
                        key = shortString(key, 120),
                        keyType = kind(key),
                        value = serialize(item, depth + 1, seen),
                    }
                end
            end
            seen[value] = nil
            return { type = "table", count = total, entries = entries, truncated = total > #entries }
        end
        return { type = safeToString(valueType), value = shortString(value, 300) }
    end

    local function packArgs(...)
        local count = _select("#", ...)
        local rawArgs = { ... }
        local values = {}
        local limit = count
        if limit > 20 then
            limit = 20
        end
        for index = 1, limit do
            local item = rawArgs[index]
            local ok, result = safeCall(function()
                return serialize(item)
            end)
            values[index] = ok and result or { type = "serialization_error", value = shortString(result, 300) }
        end
        return { count = count, values = values, truncated = count > limit }
    end

    local function instanceInfo(instance)
        return {
            class = safeToString(prop(instance, "ClassName") or "Unknown"),
            name = safeToString(prop(instance, "Name") or "Unknown"),
            path = fullName(instance),
        }
    end

    local function inc(eventName)
        eventName = eventName or "unknown"
        Scan.counts[eventName] = (Scan.counts[eventName] or 0) + 1
    end

    local function flush()
        if Scan.flushing or #Scan.buffer == 0 then
            return
        end
        Scan.flushing = true
        local chunk = _table.concat(Scan.buffer, "\n") .. "\n"
        Scan.buffer = {}
        Scan.fileText = (Scan.fileText or "") .. chunk
        if #Scan.fileText > MAX_FILE_BYTES then
            Scan.fileText = stringSub(Scan.fileText, #Scan.fileText - 3200000)
            Scan.fileText = "{\"event\":\"scan_file_trimmed\",\"time\":" .. quote(now()) .. "}\n" .. Scan.fileText
        end
        writeText(filePath, Scan.fileText)
        if folderAvailable then
            writeText(folder .. "/latest.log", Scan.fileText)
        end
        Scan.flushing = false
    end

    local function logRecord(record)
        if not Scan.active then
            return
        end
        record.time = now()
        local ok, encoded = safeCall(function()
            return encode(record)
        end)
        if not ok then
            encoded = encode({ event = "encode_error", message = shortString(encoded, 500), time = now() })
        end
        Scan.buffer[#Scan.buffer + 1] = encoded
        inc(record.event or "unknown")
        if #Scan.buffer >= FLUSH_EVERY then
            flush()
        end
    end

    function Scan:Connect(signal, callback)
        if not self.active or not signal or not callable(callback) then
            return nil
        end
        local ok, conn = safeCall(function()
            if signal.Connect then
                return signal:Connect(callback)
            end
            return nil
        end)
        if ok and conn then
            self.conns[#self.conns + 1] = conn
            return conn
        end
        return nil
    end

    function Scan:Stop(reason)
        if not self.active then
            return
        end
        logRecord({ event = "scan_stop", reason = safeToString(reason or "manual") })
        self.active = false
        for _, conn in _ipairs(self.conns) do
            safeCall(function()
                if conn and conn.Disconnect then
                    conn:Disconnect()
                end
            end)
        end
        flush()
    end

    local interestingTerms = {
        "role", "round", "state", "status", "match", "mode", "map", "alive", "dead",
        "murder", "sheriff", "innocent", "hero", "winner", "victory", "weapon",
        "gun", "knife", "coin", "currency", "token", "bag", "cash", "drop",
        "playerdata", "gameplay", "inventory",
    }

    local coinTerms = { "coin", "coincontainer", "coin_server", "currency", "token", "cash", "money", "candy" }
    local gunDropTerms = { "gundrop", "gun drop", "droppedgun", "dropped gun", "dropgun", "gunpickup" }
    local roundStartTerms = { "roundstart", "round_start", "gamestart", "matchstart", "giveweapon", "roleselect" }
    local roundEndTerms = { "roundend", "round_end", "victoryscreen", "winner", "murdererdied", "clear1v1", "cancelled1v1" }
    local roleTerms = { "role", "roleselect", "playerdatachanged", "murder", "sheriff", "innocent", "hero", "giveweapon" }

    local function pathText(instance)
        return fullName(instance)
    end

    local function isPlayerOwnedPath(path)
        local lower = stringLower(path)
        if stringFind(lower, "players.") then
            return true
        end
        if LocalPlayer then
            local name = stringLower(safeToString(prop(LocalPlayer, "Name") or ""))
            if name ~= "" and stringFind(lower, "workspace." .. name .. ".") then
                return true
            end
        end
        return false
    end

    local function inWorkspace(instance)
        if instance == Workspace then
            return true
        end
        local ok, result = safeCall(function()
            return Workspace and instance:IsDescendantOf(Workspace)
        end)
        return ok and result == true
    end

    local function objectPosition(instance)
        local pos = nil
        if isA(instance, "BasePart") then
            safeCall(function()
                pos = instance.Position
            end)
        elseif isA(instance, "Model") then
            safeCall(function()
                pos = instance:GetPivot().Position
            end)
        elseif isA(instance, "Tool") then
            local handle = nil
            safeCall(function()
                handle = instance:FindFirstChild("Handle")
            end)
            if handle then
                safeCall(function()
                    pos = handle.Position
                end)
            end
        end
        if pos then
            return serialize(pos)
        end
        return nil
    end

    local function attributesInfo(instance)
        local attrs = nil
        safeCall(function()
            if instance.GetAttributes then
                attrs = instance:GetAttributes()
            end
        end)
        if _type(attrs) == "table" and tableCount(attrs) > 0 then
            return serialize(attrs)
        end
        return nil
    end

    local function tagsForPath(path)
        local tags = {}
        if containsAny(path, coinTerms) then tags[#tags + 1] = "coin" end
        if containsAny(path, gunDropTerms) then tags[#tags + 1] = "gun_drop" end
        if containsAny(path, roundStartTerms) or containsAny(path, roundEndTerms) then tags[#tags + 1] = "round" end
        if containsAny(path, roleTerms) then tags[#tags + 1] = "role" end
        if containsAny(path, { "remote", "gameplay", "clientservice", "weaponservice" }) then tags[#tags + 1] = "event" end
        if #tags == 0 and containsAny(path, interestingTerms) then tags[#tags + 1] = "interesting" end
        return tags
    end

    local function isRemote(instance)
        return isA(instance, "RemoteEvent") or isA(instance, "RemoteFunction")
    end

    local function inferRoundFromRemote(remote, packedArgs)
        local path = pathText(remote)
        if containsAny(path, roundStartTerms) then
            Scan.summary.lastRoundState = "started_or_role_assignment"
            logRecord({ event = "round_state_signal", state = Scan.summary.lastRoundState, source = instanceInfo(remote), args = packedArgs })
        elseif containsAny(path, roundEndTerms) then
            Scan.summary.lastRoundState = "ended_or_transition"
            logRecord({ event = "round_state_signal", state = Scan.summary.lastRoundState, source = instanceInfo(remote), args = packedArgs })
        end
        if containsAny(path, roleTerms) then
            Scan.summary.lastRoleSignal = path
            logRecord({ event = "role_state_signal", source = instanceInfo(remote), args = packedArgs })
        end
    end

    local function attachInbound(remote)
        if Scan.inboundRemotes[remote] or not isA(remote, "RemoteEvent") then
            return
        end
        Scan.inboundRemotes[remote] = true
        local signal = prop(remote, "OnClientEvent")
        Scan:Connect(signal, function(...)
            protected("remote_inbound", function(...)
                local packed = packArgs(...)
                logRecord({ event = "remote_inbound", method = "OnClientEvent", remote = instanceInfo(remote), tags = tagsForPath(pathText(remote)), args = packed })
                inferRoundFromRemote(remote, packed)
            end, ...)
        end)
    end

    local function rememberRemote(remote)
        if not isRemote(remote) or Scan.discoveredRemotes[remote] then
            return
        end
        Scan.discoveredRemotes[remote] = true
        local path = pathText(remote)
        logRecord({ event = "remote_discovered", remote = instanceInfo(remote), tags = tagsForPath(path), attributes = attributesInfo(remote) })
        attachInbound(remote)
    end

    local function readValue(instance)
        local ok, value = safeCall(function()
            return instance.Value
        end)
        if ok then
            return serialize(value)
        end
        return { type = "read_error", value = shortString(value, 200) }
    end

    local function watchValue(instance, reason)
        if Scan.watchedValues[instance] or not isA(instance, "ValueBase") then
            return
        end
        local path = pathText(instance)
        if not containsAny(path, interestingTerms) then
            return
        end
        Scan.watchedValues[instance] = true
        Scan.summary.valueStatesSeen = Scan.summary.valueStatesSeen + 1
        logRecord({ event = "state_value_discovered", reason = reason, valueObject = instanceInfo(instance), value = readValue(instance), tags = tagsForPath(path), attributes = attributesInfo(instance) })
        Scan:Connect(prop(instance, "Changed"), function()
            protected("state_value_changed", function()
                local value = readValue(instance)
                local tags = tagsForPath(pathText(instance))
                if containsAny(pathText(instance), roundStartTerms) then
                    Scan.summary.lastRoundState = "value_started_or_active"
                elseif containsAny(pathText(instance), roundEndTerms) then
                    Scan.summary.lastRoundState = "value_ended_or_transition"
                end
                logRecord({ event = "state_value_changed", valueObject = instanceInfo(instance), value = value, tags = tags })
            end)
        end)
    end

    local function watchAttributes(instance, reason)
        if Scan.watchedAttributes[instance] then
            return
        end
        local path = pathText(instance)
        if not containsAny(path, interestingTerms) then
            return
        end
        local attrs = attributesInfo(instance)
        if not attrs then
            return
        end
        Scan.watchedAttributes[instance] = true
        logRecord({ event = "attributes_discovered", reason = reason, instance = instanceInfo(instance), tags = tagsForPath(path), attributes = attrs })

        local rawAttrs = nil
        safeCall(function()
            rawAttrs = instance:GetAttributes()
        end)
        if _type(rawAttrs) == "table" then
            for attrName in _pairs(rawAttrs) do
                safeCall(function()
                    local signal = instance:GetAttributeChangedSignal(attrName)
                    Scan:Connect(signal, function()
                        protected("attribute_changed", function()
                            local value = nil
                            safeCall(function()
                                value = instance:GetAttribute(attrName)
                            end)
                            logRecord({
                                event = "attribute_changed",
                                instance = instanceInfo(instance),
                                attribute = safeToString(attrName),
                                value = serialize(value),
                                tags = tagsForPath(pathText(instance)),
                            })
                        end)
                    end)
                end)
            end
        end
    end

    local function classifyWorldObject(instance)
        if not inWorkspace(instance) then
            return
        end

        local path = pathText(instance)
        local lowerPath = stringLower(path)
        local name = stringLower(prop(instance, "Name") or "")
        local isCoin = containsAny(lowerPath, coinTerms)
        local isGunDrop = containsAny(lowerPath, gunDropTerms)
        local isLooseGunCandidate = name == "gun" and stringFind(lowerPath, "workspace.") and not isPlayerOwnedPath(path)

        if isCoin and not Scan.coinObjects[instance] then
            Scan.coinObjects[instance] = true
            Scan.summary.coinsSeen = Scan.summary.coinsSeen + 1
            logRecord({ event = "coin_object_discovered", object = instanceInfo(instance), position = objectPosition(instance), attributes = attributesInfo(instance), reason = "name_or_path_match" })
        end

        if (isGunDrop or isLooseGunCandidate) and not Scan.gunDropObjects[instance] then
            Scan.gunDropObjects[instance] = true
            Scan.summary.gunDropsSeen = Scan.summary.gunDropsSeen + 1
            logRecord({
                event = isGunDrop and "gun_drop_object_discovered" or "gun_drop_candidate_discovered",
                object = instanceInfo(instance),
                position = objectPosition(instance),
                attributes = attributesInfo(instance),
                reason = isGunDrop and "drop_name_or_path_match" or "loose_workspace_gun_candidate",
            })
        end
    end

    local function inspectInstance(instance, reason)
        if not instance or not Scan.active then
            return
        end
        rememberRemote(instance)
        watchValue(instance, reason)
        watchAttributes(instance, reason)
        classifyWorldObject(instance)
    end

    local function safeWait(seconds)
        if _type(task) == "table" and callable(task.wait) then
            local ok = safeCall(task.wait, seconds)
            if ok then
                return
            end
        end
        if callable(wait) then
            safeCall(wait, seconds)
            return
        end
        if RunService then
            local heartbeat = prop(RunService, "Heartbeat")
            if heartbeat and heartbeat.Wait then
                safeCall(function()
                    heartbeat:Wait()
                end)
            end
        end
    end

    local function scanRoot(root, reason)
        if not root or not Scan.active then
            return
        end
        local firstRootScan = Scan.scannedRoots[root] ~= true
        Scan.scannedRoots[root] = true

        inspectInstance(root, reason)
        local ok, descendants = safeCall(function()
            return root:GetDescendants()
        end)
        if ok and _type(descendants) == "table" then
            for index, instance in _ipairs(descendants) do
                inspectInstance(instance, reason)
                if index % 300 == 0 then
                    safeWait()
                end
            end
        end

        if not firstRootScan then
            return
        end

        local addedSignal = prop(root, "DescendantAdded")
        Scan:Connect(addedSignal, function(instance)
            if _type(task) == "table" and callable(task.defer) then
                local okDefer = safeCall(task.defer, function()
                    protected("descendant_added", function()
                        inspectInstance(instance, "descendant_added")
                    end)
                end)
                if okDefer then
                    return
                end
            end
            protected("descendant_added_direct", function()
                inspectInstance(instance, "descendant_added")
            end)
        end)

        local removingSignal = prop(root, "DescendantRemoving")
        Scan:Connect(removingSignal, function(instance)
            protected("descendant_removing", function()
                if Scan.coinObjects[instance] then
                    logRecord({ event = "coin_object_removed", object = instanceInfo(instance) })
                end
                if Scan.gunDropObjects[instance] then
                    logRecord({ event = "gun_drop_object_removed", object = instanceInfo(instance) })
                end
            end)
        end)
    end

    local function roots()
        local list = {}
        local names = { "ReplicatedStorage", "ReplicatedFirst", "Workspace", "Lighting", "StarterGui", "StarterPack", "StarterPlayer" }
        for _, name in _ipairs(names) do
            local service = getService(name)
            if service then
                list[#list + 1] = service
            end
        end
        if LocalPlayer then
            list[#list + 1] = LocalPlayer
            local playerGui = prop(LocalPlayer, "PlayerGui")
            local backpack = prop(LocalPlayer, "Backpack")
            local character = prop(LocalPlayer, "Character")
            if playerGui then list[#list + 1] = playerGui end
            if backpack then list[#list + 1] = backpack end
            if character then list[#list + 1] = character end
        end
        return list
    end

    local function updateStatus()
        local text = "running: " .. VERSION
            .. "\nmode: passive state scan/no outbound hook/no remote firing"
            .. "\nfile: " .. filePath
            .. "\ncoinsSeen: " .. safeToString(Scan.summary.coinsSeen)
            .. "\ngunDropsSeen: " .. safeToString(Scan.summary.gunDropsSeen)
            .. "\nvalueStatesSeen: " .. safeToString(Scan.summary.valueStatesSeen)
            .. "\nlastRoundState: " .. safeToString(Scan.summary.lastRoundState)
            .. "\nlastRoleSignal: " .. safeToString(Scan.summary.lastRoleSignal)
            .. "\n"
        writeText(statusPath, text)
        if folderAvailable then
            writeText(folder .. "/status.txt", text)
        end
    end

    local function spawnTask(name, callback)
        local runner = function()
            protected(name, callback)
        end
        if _type(task) == "table" and callable(task.spawn) then
            local ok = safeCall(task.spawn, runner)
            if ok then
                return
            end
        end
        if callable(spawn) then
            local ok = safeCall(spawn, runner)
            if ok then
                return
            end
        end
        if _type(_coroutine) == "table" and callable(_coroutine.wrap) then
            local ok, wrapped = safeCall(_coroutine.wrap, runner)
            if ok and callable(wrapped) then
                safeCall(wrapped)
                return
            end
        end
        runner()
    end

    writeText(filePath, "")

    logRecord({
        event = "scan_start",
        version = VERSION,
        file = filePath,
        placeId = prop(_game, "PlaceId"),
        jobId = safeToString(prop(_game, "JobId") or ""),
        localPlayer = LocalPlayer and { name = safeToString(prop(LocalPlayer, "Name") or ""), userId = prop(LocalPlayer, "UserId") } or nil,
        capabilities = {
            writefile = callable(writefileFn),
            outboundHook = false,
            remoteFiring = false,
        },
        focus = {
            "coins",
            "gun_drops",
            "round_state",
            "roles",
            "remote_names",
            "inbound_events",
        },
    })

    spawnTask("initial_scan", function()
        for _, root in _ipairs(roots()) do
            if Scan.active then
                scanRoot(root, "initial_scan")
            end
        end
        if LocalPlayer then
            Scan:Connect(prop(LocalPlayer, "CharacterAdded"), function(character)
                protected("character_added", function()
                    scanRoot(character, "character_added")
                end)
            end)
        end
        logRecord({ event = "initial_scan_complete", summary = Scan.summary })
        flush()
        updateStatus()
    end)

    spawnTask("periodic_rescan", function()
        while Scan.active do
            safeWait(12)
            if Workspace then
                scanRoot(Workspace, "periodic_workspace_rescan")
            end
            if ReplicatedStorage then
                scanRoot(ReplicatedStorage, "periodic_replicated_rescan")
            end
            logRecord({ event = "scan_heartbeat", counts = Scan.counts, bufferSize = #Scan.buffer, summary = Scan.summary })
            flush()
            updateStatus()
        end
    end)

    spawnTask("flush_loop", function()
        while Scan.active do
            safeWait(2)
            flush()
            updateStatus()
        end
    end)

    flush()
    updateStatus()
end

local ok = protected("main", main)
if not ok then
    writeText(statusPath, "main failed; check " .. crashPath .. "\n")
end
